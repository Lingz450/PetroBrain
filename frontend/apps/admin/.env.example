# Public base URL of the PetroBrain FastAPI backend.
# Read by lib/session/store.ts as the default for apiBaseUrl when
# window.__PB_API__ is not injected (i.e. standalone Vercel deploys).
#
# Local dev: leave unset; the store falls back to http://localhost:8000.
# Vercel:    set to the deployed backend, e.g. https://api.petrobrain.example.
NEXT_PUBLIC_API_BASE_URL=
